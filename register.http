### Register the primary test user
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "username": "testuser4",
  "email": "test4@example.com",
  "password": "password123"
}

### Log in as the primary user
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "username": "testuser4",
  "password": "password123"
}

> {%
    client.global.set("authToken", response.body.token);
%}

### Register a second user, to prove cross-user protection for real
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "username": "otheruser",
  "email": "other@example.com",
  "password": "password123"
}

### Log in as the second user
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "username": "otheruser",
  "password": "password123"
}

> {%
    client.global.set("otherToken", response.body.token);
%}

### Create a category as the primary user
POST http://localhost:8080/api/categories
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Groceries",
  "type": "EXPENSE"
}

> {%
    client.global.set("categoryId", response.body.id);
%}

### List categories
GET http://localhost:8080/api/categories
Authorization: Bearer {{authToken}}

### Get one category
GET http://localhost:8080/api/categories/{{categoryId}}
Authorization: Bearer {{authToken}}

### Update it
PUT http://localhost:8080/api/categories/{{categoryId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "name": "Groceries & Household",
  "type": "EXPENSE"
}

### THE REAL TEST: try accessing user 1's category using user 2's token (should 404, not 200)
GET http://localhost:8080/api/categories/{{categoryId}}
Authorization: Bearer {{otherToken}}

### Create a transaction using the category we made
POST http://localhost:8080/api/transactions
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "categoryId": {{categoryId}},
  "amount": 45.50,
  "description": "Weekly groceries",
  "date": "2026-06-20",
  "type": "EXPENSE"
}

> {%
    client.global.set("transactionId", response.body.id);
%}

### List transactions
GET http://localhost:8080/api/transactions
Authorization: Bearer {{authToken}}

### Get one transaction
GET http://localhost:8080/api/transactions/{{transactionId}}
Authorization: Bearer {{authToken}}

### Update it
PUT http://localhost:8080/api/transactions/{{transactionId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "categoryId": {{categoryId}},
  "amount": 52.00,
  "description": "Weekly groceries (updated)",
  "date": "2026-06-20",
  "type": "EXPENSE"
}

### Try a categoryId that doesn't exist (should 404)
POST http://localhost:8080/api/transactions
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "categoryId": 999999,
  "amount": 10.00,
  "date": "2026-06-20",
  "type": "EXPENSE"
}

### Try a negative amount (should 400)
POST http://localhost:8080/api/transactions
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "categoryId": {{categoryId}},
  "amount": -10.00,
  "date": "2026-06-20",
  "type": "EXPENSE"
}

### Delete the transaction
DELETE http://localhost:8080/api/transactions/{{transactionId}}
Authorization: Bearer {{authToken}}

### Create a budget tied to the category
POST http://localhost:8080/api/budgets
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "categoryId": {{categoryId}},
  "limitAmount": 200.00,
  "startDate": "2026-06-01",
  "endDate": "2026-06-30"
}

> {%
    client.global.set("budgetId", response.body.id);
%}

### Create an overall budget with no category
POST http://localhost:8080/api/budgets
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "limitAmount": 1000.00,
  "startDate": "2026-06-01",
  "endDate": "2026-06-30"
}

> {%
    client.global.set("budgetId2", response.body.id);
%}

### List budgets
GET http://localhost:8080/api/budgets
Authorization: Bearer {{authToken}}

### Try an invalid date range (should 400)
POST http://localhost:8080/api/budgets
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "limitAmount": 100.00,
  "startDate": "2026-06-30",
  "endDate": "2026-06-01"
}

### Clean up
DELETE http://localhost:8080/api/budgets/{{budgetId}}
Authorization: Bearer {{authToken}}

###
DELETE http://localhost:8080/api/budgets/{{budgetId2}}
Authorization: Bearer {{authToken}}

###
DELETE http://localhost:8080/api/transactions/{{transactionId}}
Authorization: Bearer {{authToken}}

###
DELETE http://localhost:8080/api/categories/{{categoryId}}
Authorization: Bearer {{authToken}}

### No token at all (should 401)
GET http://localhost:8080/api/categories

### As testuser4 (now ADMIN) — should succeed
GET http://localhost:8080/api/admin/users
Authorization: Bearer {{authToken}}

### As otheruser (still USER) — should be 403, not 401
GET http://localhost:8080/api/admin/users
Authorization: Bearer {{otherToken}}